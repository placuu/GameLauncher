<Window x:Class="GameLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        Title="Game Launcher" Height="450" Width="800"
        Icon="/Assets/app_icon.png"
        >

    <Grid>
        <Grid Background="{DynamicResource PrimaryBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="20,10">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Button Width="40" Height="40" Margin="5" Background="{DynamicResource GamesBackground}" BorderThickness="0" Cursor="Hand" Click="AddGame_Click">
                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{DynamicResource PrimaryText}" Stretch="Uniform" Height="20" Width="20" HorizontalAlignment="Left" VerticalAlignment="Top" />
                    </Button>

                <Button Width="40" Height="40" Margin="5" Background="{DynamicResource GamesBackground}" BorderThickness="0" Cursor="Hand" Click="Settings_Click">
                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.44,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.56,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.56,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.44,18.68 16.04,18.35 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                      Fill="{DynamicResource PrimaryText}"
                      Stretch="Uniform"
                      Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
                <TextBlock Text="MOJA BIBLIOTEKA" 
                Foreground="{DynamicResource PrimaryText}" FontSize="28" FontWeight="Bold" 
                Margin="20,20,20,10" FontFamily="Segoe UI"/>
            </DockPanel>
            <ListBox Grid.Row="1" 
             ItemsSource="{Binding Games}" 
             Background="Transparent" BorderThickness="0"
             Margin="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource GamesBackground}" 
                        CornerRadius="10" Margin="5" Padding="10" 
                        Width="1000" 
                        Height="{Binding DataContext.TileWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        MinHeight="70">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                Width="120" 
                                VerticalAlignment="Stretch" 
                                Background="{DynamicResource BorderColor}" 
                                CornerRadius="5">
                                    <Viewbox Margin="10" Opacity="0.2">
                                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="{DynamicResource PrimaryText}"/>
                                    </Viewbox>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" 
                                    Foreground="{DynamicResource PrimaryText}" 
                                    FontSize="18" FontWeight="Bold"
                                    TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding Description}" 
                                    Foreground="#AAAAAA" 
                                    FontSize="14"
                                    TextWrapping="Wrap"
                                    Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
