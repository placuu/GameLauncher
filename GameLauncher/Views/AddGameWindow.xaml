<Window x:Class="GameLauncher.Views.AddGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher.Views"
        mc:Ignorable="d"
        Title="Dodaj grę" Height="450" Width="800"    Background="#1E1E1E"
        Icon="/Assets/app_icon.png" WindowStartupLocation="CenterOwner">
        
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Dodaj nową grę" Foreground="White" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="Tytuł gry:" Foreground="#AAAAAA" Margin="0 10 0 5"/>
            <TextBox Height="30" Background="#2D2D2D" Foreground="White" BorderBrush="#3E3E3E"/>

            <TextBlock Text="Opis gry:" Foreground="#AAAAAA" Margin="0 10 0 5"/>
            <TextBox Height="30" Background="#2D2D2D" Foreground="White" BorderBrush="#3E3E3E"/>

            <TextBlock Text="Ścieżka do pliku (.exe):" Foreground="#AAAAAA" Margin="0 10 0 5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBox Height="30" Background="#2D2D2D" Foreground="White" BorderBrush="#3E3E3E"/>
                <Button Grid.Column="1" Content="Przeglądaj..." Width="80" Margin="0 0 0 0"/>
            </Grid>

            <Button Content="Zapisz" Margin="200,30,200,0" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold" FontSize="15"/>
        </StackPanel>
    </Grid>
</Window>
