<Window x:Class="GameLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher.Views"
        mc:Ignorable="d"
        Title="Ustawienie" Height="450" Width="800"  Background="{DynamicResource PrimaryBackground}"
        Icon="/Assets/app_icon.png"
        WindowStartupLocation="CenterOwner"
        >
        
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="USTAWIENIE" Foreground="{DynamicResource PrimaryText}" FontSize="20" 
                       FontWeight="Bold" Margin="0,0,20,0"/>
            <TextBlock Text="Wygląd" Foreground="{DynamicResource AccentColor}" FontWeight="SemiBold"
                       FontSize="12" Margin="0,10,0,5"/>
            <Separator Background="#333" Margin="0,0,0,15"/>
            <DockPanel>
                <TextBlock Text="Tryb jasny" Foreground="{DynamicResource PrimaryText}" 
                           VerticalAlignment="Center"/>
                <CheckBox x:Name="ThemeToggle" HorizontalAlignment="Right"
                          VerticalAlignment="Center" Cursor="Hand" Checked="ThemeToggle_Checked" 
                          Unchecked="ThemeToggle_Checked"/>
            </DockPanel>
            <TextBlock Text="Wielkość kafelków gier" Foreground="{DynamicResource PrimaryText}" 
                       Margin="0,5,0,5"/>
            <Slider x:Name="TileSizeSlider" Minimum="90" Maximum="210" Value="{Binding TileWidth, UpdateSourceTrigger=PropertyChanged}" 
                    TickFrequency="10" IsSnapToTickEnabled="True" Cursor="Hand"/>
            <TextBlock Text="{Binding ElementName=TileSizeSlider, Path=Value, 
                       StringFormat={}{0} px}" Foreground="#888" HorizontalAlignment="Right"
                       FontSize="11" Margin="0,5,0,15"/>
            <TextBlock Text="Systemowe" Foreground="{DynamicResource AccentColor}" FontWeight="SemiBold"
                       FontSize="12" Margin="0,10,0,5"/>
            <Separator Background="#333" Margin="0,0,0,15"/>
            <DockPanel>
                <TextBlock Text="Uruchamiaj przy starcie systemu" Foreground="{DynamicResource PrimaryText}"/>
                <CheckBox x:Name="AutoStartCheck" HorizontalAlignment="Right" 
                          VerticalAlignment="Center" Cursor="Hand"/>
            </DockPanel>
            <Button x:Name="ResetSizeButton" Content="Resetuj rozmiar okna głównego" 
                    Height="30" Background="{DynamicResource GamesBackground}" Foreground="{DynamicResource PrimaryText}" 
                    BorderBrush="#444" Cursor="Hand" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,40,0,0">
                <Button Content="ZAPISZ" Width="100" Height="30" Background="{DynamicResource AccentColor}"
                        Foreground="White" FontWeight="Bold" Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button x:Name="CancelButton" Content="ANULUJ" Width="100" Height="30"
                        Background="#444" Foreground="White" FontWeight="Bold" 
                        Cursor="Hand" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
        
    </Grid>
</Window>
